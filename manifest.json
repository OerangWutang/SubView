{
  "manifest_version": 3,
  "name": "SubView",
  "version": "0.1.0",
  "description": "Pre-transaction trial and subscription detection with privacy-first reminders.",
  "permissions": ["storage", "alarms", "notifications", "downloads", "tabs", "scripting"],
  "host_permissions": [],
  "optional_host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SubView"
  },
  "options_page": "options.html"
}
